# Supabase (PostgreSQL, Auth, Storage — EU region recommended)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# JWT secret for offline token verification (fallback when Supabase auth API is unreachable).
# Find it in: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# Direct Postgres URI (Settings → Database) — used by scripts/validate_setup.py for SELECT 1 + pgvector
SUPABASE_DB_URL=

# Single-tenant playground: UUID of your `tenants` row (required for ingest→Supabase)
COMPILORE_DEFAULT_TENANT_ID=

# Optional: override Claude pricing for cost logging (USD per million tokens)
# COMPILE_ANTHROPIC_INPUT_PER_MTOK=3
# COMPILE_ANTHROPIC_OUTPUT_PER_MTOK=15
# QUERY_SONNET_INPUT_PER_MTOK=3
# QUERY_SONNET_OUTPUT_PER_MTOK=15
# GATE_HAIKU_INPUT_PER_MTOK=1
# GATE_HAIKU_OUTPUT_PER_MTOK=5

# LLM providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# LangSmith (tracing / token monitoring)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=compilore

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO

# Admin: one-time password-setting endpoint (POST /admin/set-password).
# Set to a strong random secret; leave unset to disable the endpoint entirely.
ADMIN_TOKEN=

# Wiki repository (path to Git-versioned wiki root; default relative to project root)
WIKI_REPO_PATH=wiki

# Force PyMuPDF adapter for all PDFs (bypass Docling).
# Use for debugging or if Docling causes issues.
# FORCE_PYMUPDF=false
